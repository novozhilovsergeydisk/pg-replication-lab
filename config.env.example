# ============================================================================
#  Конфигурация практикума по потоковой репликации PostgreSQL.
#
#  Скопируйте этот файл и отредактируйте под свои серверы:
#      cp config.env.example config.env
#
#  ВНИМАНИЕ: пароль роли репликации здесь НЕ храним.
#  Он спрашивается при запуске скрипта или передаётся через переменную
#  окружения REPL_PASSWORD (см. README).
# ============================================================================

# --- Версия и идентичность УЧЕБНОГО кластера --------------------------------
# Учебный кластер живёт ОТДЕЛЬНО от системного (порт 5432) и не задевает его.
PG_VERSION="16"            # мажорная версия PostgreSQL. ДОЛЖНА совпадать на обоих серверах!
CLUSTER_NAME="training"    # имя учебного кластера. На нём завязаны предохранители — не меняйте.
PG_PORT="5433"            # отдельный порт учебного кластера. НЕ 5432.

# --- Роли серверов (публичные IP, связь через интернет) ---------------------
MASTER_HOST="146.185.235.231"   # источник (primary). Ваш сервер в РФ.
REPLICA_HOST="89.127.200.68"      # приёмник (standby). Сервер в DE.

# --- Репликация -------------------------------------------------------------
REPL_USER="replicator"      # роль с атрибутом REPLICATION
REPL_SLOT="training_slot"    # имя физического слота репликации на мастере

# --- TLS / безопасность -----------------------------------------------------
# Трафик репликации идёт через интернет, поэтому шифруем обязательно.
#   require     — шифрование без проверки сертификата (защита от пассивного перехвата)
#   verify-ca   — + проверка, что сертификат подписан доверенным CA (защита от MITM)  [рекомендуется]
#   verify-full — + проверка, что имя/адрес в сертификате совпадает с MASTER_HOST
SSLMODE="verify-ca"

# Куда реплика положит/ищет корневой сертификат мастера (для verify-ca/verify-full).
# Скопируйте его с мастера заранее:  scp МАСТЕР:.../server.crt РЕПЛИКА:/tmp/master-server.crt
ROOTCERT="/tmp/master-server.crt"
